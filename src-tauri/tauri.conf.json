{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDflow",
  "version": "0.2.4",
  "identifier": "com.kael.mdflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MDflow",
        "width": 1100,
        "height": 740,
        "minWidth": 640,
        "minHeight": 420
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kael-wanderer/MDflow/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyMTREMzJEQ0MxOEYxNgpSV1FXajhIY01rMGhDSXlkK0dRYkdqaVY4SC81T1F2Q25obmFvZm9TbkdkVGtKeVNybXdBaWhiLwo="
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "txt"],
        "contentTypes": [
          "net.daringfireball.markdown",
          "public.plain-text"
        ],
        "name": "Markdown and Text Document",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["pdf"],
        "contentTypes": ["com.adobe.pdf"],
        "name": "PDF Document",
        "role": "Viewer",
        "rank": "Default"
      }
    ]
  }
}
